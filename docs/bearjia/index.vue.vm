<template>
  <div class="app-container">
    <ProTable
      ref="proTableRef"
      :api="tableApi"
      :columns="columns"
      :searchFields="searchFields"
      :initialSearchParams="initialSearchParams"
      :exportConfig="exportConfig"
#if($tplCategory == 'tree')
      :isTreeTable="true"
#end
      :virtualScroll="false"
      :autoHorizontalScroll="true"
      :showColumnSettings="true"
      :sortable="true"
      rowKey="${pkColumn.javaField}"
      persistenceId="${moduleName}-${businessName}"
    >
      <!-- иҮӘе®ҡд№үж“ҚдҪңжҢүй’® -->
      <template #actions="{ selectedRowKeys, selectedRows }">
#set($isInsert=0)
#set($isEdit=0)
#foreach($column in $columns)
#if($column.insert)
#set($isInsert=1)
#end
#if($column.edit)
#set($isEdit=1)
#end
#end
#if($isInsert == 1)
        <a-button type="primary" @click="handleAdd" v-hasPermi="['${moduleName}:${businessName}:add']">
          <BearJiaIcon icon="plus-outlined" />
          ж–°еўһ
        </a-button>
#end
#if($isEdit == 1)
        <a-button
          type="primary"
          :disabled="selectedRowKeys.length !== 1"
          @click="handleEdit(selectedRows[0])"
          v-hasPermi="['${moduleName}:${businessName}:edit']"
        >
          <BearJiaIcon icon="edit-outlined" />
          дҝ®ж”№
        </a-button>
#end
        <a-button
          type="primary"
          danger
          :disabled="selectedRowKeys.length === 0"
          @click="handleDelete(selectedRowKeys)"
          v-hasPermi="['${moduleName}:${businessName}:remove']"
        >
          <BearJiaIcon icon="delete-outlined" />
          еҲ йҷӨ
        </a-button>
      </template>

      <!-- иҮӘе®ҡд№үеҲ—жёІжҹ“ -->
      <template #bodyCell="{ column, record }">
#foreach($column in $columns)
#set($javaField=$column.javaField)
#if($column.list && $column.htmlType == "datetime")
        <template v-if="column.dataIndex === '${javaField}'">
          {{ BearJiaUtil.formatTime(record.${javaField}) }}
        </template>
#elseif($column.list && "" != $column.dictType)
        <template v-if="column.dataIndex === '${javaField}'">
          <dict-tag :options="${column.javaField}Options" :value="record.${javaField}" />
        </template>
#end
#end
        <!-- ж“ҚдҪңеҲ— -->
        <template v-if="column.dataIndex === 'action'">
          <TableActionBar
            :record="record"
            :actions="[
              {
                label: 'жҹҘзңӢ',
                icon: 'eye-outlined',
                type: 'view',
                onClick: handleView
              },
              {
                label: 'дҝ®ж”№',
                icon: 'edit-outlined',
                type: 'edit',
                onClick: handleEdit,
                permissions: ['${moduleName}:${businessName}:edit']
              },
#if($tplCategory == 'tree' && $isInsert == 1)
              {
                label: 'ж–°еўһдёӢзә§',
                icon: 'plus-outlined',
                type: 'add',
                onClick: handleAddChild,
                permissions: ['${moduleName}:${businessName}:add']
              },
#end
              {
                label: 'еҲ йҷӨ',
                icon: 'delete-outlined',
                type: 'delete',
                danger: true,
                onClick: (record) => handleDelete([record.${pkColumn.javaField}]),
                permissions: ['${moduleName}:${businessName}:remove']
              }
            ]"
            :autoAdaptive="true"
          />
        </template>
      </template>
    </ProTable>

#if($isInsert == 1 || $isEdit == 1)
    <!-- ж–°еўһ/зј–иҫ‘еј№зӘ— -->
    <AddUpdateModal
      ref="addUpdateModalRef"
#foreach ($column in $columns)
#if(${column.dictType} != '')
      :${column.javaField}Options="${column.javaField}Options"
#end
#end
#if($tplCategory == 'tree')
      :${businessName}Options="${businessName}Options"
#end
      @success="refreshTable"
    />
#end

    <!-- иҜҰжғ…еј№зӘ— -->
    <DetailModal ref="detailModalRef" />
  </div>
</template>

<script setup>
import { getCurrentInstance, ref, computed } from 'vue';
import { message } from 'ant-design-vue';
import ProTable from '@/components/BearJiaProTable/index.vue';
import TableActionBar from '@/components/TableActionBar/index.vue';
import { BearJiaIcon } from '@/utils/BearJiaIcon.js';
import BearJiaUtil from '@/utils/BearJiaUtil.js';

#if($isInsert == 1 || $isEdit == 1)
import AddUpdateModal from './addUpdateModal.vue';
#end
import DetailModal from './detailModal.vue';
import { list${BusinessName}, del${BusinessName}#if($tplCategory == 'tree'), treeselect${BusinessName}#end } from '@/api/${moduleName}/${businessName}';

// иҺ·еҸ–еҪ“еүҚе®һдҫӢ
const { proxy } = getCurrentInstance();

// еӯ—е…ёж•°жҚ®
#if(${dicts} != '')
const { ${dicts} } = proxy.useDict(${dicts});
#end
#foreach ($column in $columns)
#if(${column.dictType} != '')
const ${column.javaField}Options = ref(${column.javaField});
#end
#end

// з»„д»¶еј•з”Ё
const proTableRef = ref();
const addUpdateModalRef = ref();
const detailModalRef = ref();

#if($tplCategory == 'tree')
// ж ‘еҪўж•°жҚ®йҖүйЎ№
const ${businessName}Options = ref([]);
#end

// иЎЁж јAPIй…ҚзҪ®
const tableApi = {
  list: list${BusinessName},
  delete: del${BusinessName},
#if($tplCategory == 'tree')
  processListData: (data) => {
    return BearJiaUtil.handleTree(data, '${treeCode}', '${treeParentCode}', 'children');
  }
#end
};

// еҲқе§ӢжҗңзҙўеҸӮж•°
const initialSearchParams = {
#foreach($column in $columns)
#if($column.query)
  ${column.javaField}: null,
#end
#end
};

// еҜјеҮәй…ҚзҪ®
const exportConfig = {
  url: '/${moduleName}/${businessName}/export',
  fileName: '${functionName}ж•°жҚ®'
};

// е·Ҙе…·ж Ҹй…ҚзҪ®
const toolbarConfig = {
  refresh: true,
  density: true,
  fullscreen: true,
  columnSettings: true,
  settings: true
};

// жҗңзҙўеӯ—ж®өй…ҚзҪ®
const searchFields = computed(() => [
#foreach($column in $columns)
#if($column.query)
#set($dictType=$column.dictType)
#set($AttrName=$column.javaField.substring(0,1).toUpperCase() + ${column.javaField.substring(1)})
#set($parentheseIndex=$column.columnComment.indexOf("пјҲ"))
#if($parentheseIndex != -1)
#set($comment=$column.columnComment.substring(0, $parentheseIndex))
#else
#set($comment=$column.columnComment)
#end
#if($column.htmlType == "input")
  {name: '${column.javaField}', label: '${comment}', type: 'input'},
#elseif(($column.htmlType == "select" || $column.htmlType == "radio") && "" != $dictType)
  {name: '${column.javaField}', label: '${comment}', type: 'select', options: ${column.javaField}.value},
#elseif($column.htmlType == "datetime" && $column.queryType != "BETWEEN")
  {name: '${column.javaField}', label: '${comment}', type: 'date'},
  {name: '${column.javaField}', label: '${comment}', type: 'daterange'},
#end
#end
#end
]);

// иЎЁж јеҲ—й…ҚзҪ®
const columns = [
#foreach($column in $columns)
#set($javaField=$column.javaField)
#set($parentheseIndex=$column.columnComment.indexOf("пјҲ"))
#if($parentheseIndex != -1)
#set($comment=$column.columnComment.substring(0, $parentheseIndex))
#else
#set($comment=$column.columnComment)
#end
#if($column.list)
  {
    title: '${comment}',
    dataIndex: '${javaField}',
    key: '${javaField}',
#if($column.pk)
    width: 80,
#end
    align: 'center',
    ellipsis: true
  },
#end
#end
  {
    title: 'ж“ҚдҪң',
    dataIndex: 'action',
    key: 'action',
    width: 240,
    align: 'center',
    fixed: 'right',
    resizable: false
  }
];

// ж–°еўһ
const handleAdd = () => {
#if($isInsert == 1)
  addUpdateModalRef.value.open('add');
#end
};

// зј–иҫ‘
const handleEdit = (record) => {
#if($isEdit == 1)
  addUpdateModalRef.value.open('edit', record);
#end
};

#if($tplCategory == 'tree' && $isInsert == 1)
// ж–°еўһдёӢзә§
const handleAddChild = (record) => {
  addUpdateModalRef.value.open('add', { ${treeParentCode}: record.${treeCode} });
};
#end

// жҹҘзңӢиҜҰжғ…
const handleView = (record) => {
  detailModalRef.value.open(record);
};

// еҲ йҷӨ
const handleDelete = async (ids) => {
  try {
    await del${BusinessName}(ids.join(','));
    message.success('еҲ йҷӨжҲҗеҠҹ');
    refreshTable();
  } catch (error) {
    console.error('еҲ йҷӨеӨұиҙҘ:', error);
  }
};

// еҲ·ж–°иЎЁж ј
const refreshTable = () => {
  proTableRef.value.reload();
};

#if($tplCategory == 'tree')
// иҺ·еҸ–ж ‘еҪўйҖүжӢ©ж•°жҚ®
const getTreeSelect = async () => {
  try {
    const response = await treeselect${BusinessName}();
    ${businessName}Options.value = response.data || [];
  } catch (error) {
    console.error('иҺ·еҸ–ж ‘еҪўж•°жҚ®еӨұиҙҘ:', error);
  }
};

// еҲқе§ӢеҢ–ж—¶иҺ·еҸ–ж ‘еҪўж•°жҚ®
getTreeSelect();
#end
</script>

<style lang="less" scoped>
.app-container {
  padding: 16px;
}
</style>
