# Base
VITE_APP_TITLE=BearJia Admin
VITE_APP_ENV=development
VITE_APP_BASE_API=/dev-api

# Dev server
VITE_PORT=8090
VITE_BASE_URL=./

# Dev proxy target (used when VITE_APP_BASE_API=/dev-api)
VITE_PROXY_TARGET=http://localhost:8081

# Optional: build visualizer (generates dist/stats.html)
VITE_VISUALIZER=false
VITE_VISUALIZER_OPEN=false

# Deprecated: old variable name (still supported in some places)
# VITE_API_DOMAIN=/dev-api
VITE_AGENT_UI_URL = 'http://localhost:5174'
