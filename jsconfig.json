{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@components/*": ["src/components/*"],
      "@utils/*": ["src/utils/*"],
      "@api/*": ["src/api/*"],
      "@views/*": ["src/views/*"],
      "@stores/*": ["src/stores/*"],
      "@assets/*": ["src/assets/*"],
      "@style/*": ["src/style/*"]
    }
  },
  "include": ["src/**/*", "src/env.d.ts", "src/types/auto-imports.d.ts", "src/types/components.d.ts"]
}
